{
  "name": "@shotframe/studio",
  "version": "0.1.0",
  "private": true,
  "description": "Vite browser studio for shotframe: a live 3-pane preview UI that consumes a resolved config and renders targets with @shotframe/core.",
  "license": "MIT",
  "author": "ISEMI",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
