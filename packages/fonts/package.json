{
  "name": "@shotframe/fonts",
  "version": "0.1.0",
  "description": "Bundled open-source Latin webfonts (woff2) for shotframe, so the renderer is deterministic across OS. Package code is MIT; each bundled font keeps its own OFL/Apache license (see LICENSES/).",
  "keywords": [
    "fonts",
    "woff2",
    "webfonts",
    "fontsource",
    "shotframe",
    "deterministic"
  ],
  "license": "MIT",
  "author": "ISEMI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crisng95/shotframe.git",
    "directory": "packages/fonts"
  },
  "homepage": "https://github.com/crisng95/shotframe#readme",
  "bugs": "https://github.com/crisng95/shotframe/issues",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "files": [
    "dist",
    "fonts",
    "LICENSES"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fonts/*": "./fonts/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.6"
  }
}
